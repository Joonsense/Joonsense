# Prediction Market Aggregator configuration
# Copy this file to .env and adjust values as needed.

# Override API endpoints if required
# POLYMARKET_URL=https://gamma-api.polymarket.com/markets?limit=50
# KALSHI_URL=https://trading-api.kalshi.com/v1/events
# MANIFOLD_URL=https://api.manifold.markets/v0/markets

# Polling interval in milliseconds (default 60000)
# POLLING_INTERVAL_MS=60000

# Output file path (defaults to ./data/unified_markets.json)
# OUTPUT_PATH=/workspace/Joonsense/data/unified_markets.json

# Optional Supabase configuration
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_KEY=your_supabase_service_role_key
# SUPABASE_TABLE=prediction_markets
